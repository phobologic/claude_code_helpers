#!/usr/bin/env python3
# tk-plugin: Print skeleton tickets whose Scope: line matches any of the given file paths.

import sys
import json
import subprocess
import fnmatch
import argparse


def load_skeletons():
    result = subprocess.run(
        ['tk', 'triage', '--tag', 'skeleton', '--json', '--full'],
        capture_output=True, text=True, check=True,
    )
    return json.loads(result.stdout)


def extract_scope(body):
    if not body:
        return []
    for line in body.splitlines():
        s = line.strip().lstrip('*').strip()
        if s.lower().startswith('scope:'):
            after = s.split(':', 1)[1].strip().rstrip('*').strip()
            return [e.strip() for e in after.split(',') if e.strip()]
    return []


def entry_matches_path(entry, path):
    if any(c in entry for c in '*?['):
        return fnmatch.fnmatch(path, entry) or fnmatch.fnmatch(path, entry.rstrip('/') + '/*')
    e = entry.rstrip('/')
    if path == e or path.startswith(e + '/'):
        return True
    return e in path.split('/')


def main():
    ap = argparse.ArgumentParser(
        description='Print skeleton tickets whose Scope: line matches any of the given paths.',
    )
    ap.add_argument('paths', nargs='+', help='Files or directories to check')
    ap.add_argument('--json', action='store_true', help='Emit JSON')
    args = ap.parse_args()

    matched = []
    for t in load_skeletons():
        scope = extract_scope(t.get('body', ''))
        if not scope:
            continue
        for entry in scope:
            if any(entry_matches_path(entry, p) for p in args.paths):
                matched.append({
                    'id': t.get('id'),
                    'title': t.get('title'),
                    'scope': scope,
                    'matched_entry': entry,
                })
                break

    if args.json:
        print(json.dumps(matched, indent=2))
        return

    for m in matched:
        print(f"{m['id']}\t{m['title']}\t(scope: {', '.join(m['scope'])})")


if __name__ == '__main__':
    main()
