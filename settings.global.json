{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85"
  },
  "permissions": {
    "allow": [
      "Bash(review-setup*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/no-inline-scripts.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "jq -r '\"\\(.cwd | sub(\"^\" + env.HOME; \"~\")) | \\(.model.display_name) | ctx: \\(.context_window.used_percentage)%\"'"
  },
  "enabledPlugins": {
    "claude-worktree@phobos-plugins": true,
    "discord@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "editorMode": "vim",
  "teammateMode": "tmux",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
